# ============================================================
# App
# ============================================================
APP_ENV=development
APP_PORT=8080

# ============================================================
# Database (wajib)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solekita_dev
DB_USER=solekita
DB_PASSWORD=change-me
DB_SSLMODE=disable

# ============================================================
# JWT (wajib — generate via: openssl rand -hex 32)
# ============================================================
JWT_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars-different-from-above
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# ============================================================
# Cloudflare R2
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=solekita-dev
R2_PUBLIC_URL=
R2_BACKUP_BUCKET_NAME=solekita-backup

# ============================================================
# Fonnte (WhatsApp notification)
# ============================================================
FONNTE_TOKEN=
FONNTE_SENDER=

# ============================================================
# Tripay (payment gateway)
# Gunakan TRIPAY_BASE_URL sandbox untuk development
# ============================================================
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_BASE_URL=https://tripay.co.id/api-sandbox

# ============================================================
# Admin Panel (founder only)
# ============================================================
ADMIN_SECRET_KEY=change-me-min-32-chars

# ============================================================
# CORS
# ============================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
